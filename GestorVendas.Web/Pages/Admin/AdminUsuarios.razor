@page "/admin/usuarios"
@attribute [Authorize(Roles = "Admin")]
@inject IUsuarioService UsuarioService
@inject IEmpresaService EmpresaService
@inject SessaoService Sessao

<PageTitle>Usuários — Gestor de Vendas</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Usuários do sistema</h4>
        <p class="text-muted small mb-0">Gerentes por empresa</p>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <select value="@_empresaFiltro" @onchange="OnEmpresaChanged" class="form-select" style="max-width:300px">
            <option value="">Selecione uma empresa</option>
            @foreach (var e in _empresas)
            {
                <option value="@e.Id">@e.NomeFantasia</option>
            }
        </select>
    </div>
</div>

@if (_empresaFiltro != Guid.Empty.ToString())
{
    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-primary btn-sm" @onclick="AbrirNovo">
            <i class="bi bi-person-plus me-1"></i>Novo gerente
        </button>
    </div>
}

@if (!string.IsNullOrEmpty(_msg))
{
    <div class="alert @(_sucesso?"alert-success":"alert-danger") py-2 small mb-3">@_msg</div>
}

@if (_usuarios != null)
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead><tr>
                    <th>Nome</th><th>Login</th><th>Perfil</th><th>Status</th><th class="text-end">Ações</th>
                </tr></thead>
                <tbody>
                    @foreach (var u in _usuarios)
                    {
                        <tr>
                            <td class="fw-medium">@u.Nome</td>
                            <td class="text-muted">@u.Login</td>
                            <td><span class="badge bg-primary">@u.Perfil</span></td>
                            <td><span class="badge @(u.Ativo?"bg-success":"bg-light text-muted")">
                                @(u.Ativo?"Ativo":"Inativo")
                            </span></td>
                            <td class="text-end">
                                <button class="btn btn-link btn-sm text-primary p-0"
                                        @onclick="()=>AbrirEdicao(u)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_modal)
{
    <div class="modal d-block" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editando==null?"Novo gerente":"Editar gerente")</h5>
                    <button class="btn-close" @onclick="()=>_modal=false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Nome *</label>
                            <input @bind="_nome" class="form-control" />
                        </div>
                        @if (_editando == null)
                        {
                            <div class="col-md-6">
                                <label class="form-label">Login *</label>
                                <input @bind="_login" class="form-control" />
                            </div>
                        }
                        <div class="col-md-6">
                            <label class="form-label">@(_editando==null?"Senha *":"Nova senha")</label>
                            <input @bind="_senha" type="password" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="()=>_modal=false">Cancelar</button>
                    <button class="btn btn-primary" @onclick="Salvar" disabled="@_salvando">
                        @(_salvando?"Salvando...":"Salvar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    IEnumerable<EmpresaDto> _empresas = new List<EmpresaDto>();
    IEnumerable<UsuarioDto>? _usuarios;
    UsuarioDto? _editando;
    string _empresaFiltro = "", _nome = "", _login = "", _senha = "", _msg = "";
    bool _modal, _salvando, _sucesso;

    protected override async Task OnInitializedAsync()
        => _empresas = await EmpresaService.ListarAsync();

    async Task OnEmpresaChanged(ChangeEventArgs e)
    {
        _empresaFiltro = e.Value?.ToString() ?? "";
        if (Guid.TryParse(_empresaFiltro, out var id))
            _usuarios = await UsuarioService.ListarPorEmpresaAsync(id);
    }

    void AbrirNovo() { _editando=null; _nome=""; _login=""; _senha=""; _modal=true; }
    void AbrirEdicao(UsuarioDto u) { _editando=u; _nome=u.Nome; _login=u.Login; _senha=""; _modal=true; }

    async Task Salvar()
    {
        if (!Guid.TryParse(_empresaFiltro, out var empresaId)) return;
        _salvando=true;
        try
        {
            if (_editando==null)
                await UsuarioService.CriarAsync(
                    new CriarUsuarioRequest(_nome, _login, _senha, PerfilUsuario.Gerente, empresaId),
                    empresaId);
            else
                await UsuarioService.AtualizarAsync(_editando.Id,
                    new AtualizarUsuarioRequest(_nome, string.IsNullOrEmpty(_senha)?null:_senha));
            _msg=_editando==null?"Gerente criado!":"Gerente atualizado!"; _sucesso=true;
            _usuarios = await UsuarioService.ListarPorEmpresaAsync(empresaId);
            _modal=false;
        }
        catch(Exception ex){ _msg=ex.Message; _sucesso=false; }
        finally{ _salvando=false; }
    }
}
