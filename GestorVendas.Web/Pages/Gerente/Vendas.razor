@page "/gerente/vendas"
@page "/operador/vendas"
@attribute [Authorize(Roles = "Gerente,Operador")]
@inject IVendaService VendaService
@inject SessaoService Sessao

<PageTitle>Vendas — Gestor de Vendas</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Vendas</h4>
        <p class="text-muted small mb-0">Histórico de vendas</p>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <input @bind="_inicio" type="date" class="form-control form-control-sm" style="width:140px" />
        <span class="text-muted small">até</span>
        <input @bind="_fim" type="date" class="form-control form-control-sm" style="width:140px" />
        <button class="btn btn-primary btn-sm" @onclick="Carregar">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_msg))
{
    <div class="alert @(_sucesso?"alert-success":"alert-danger") py-2 small mb-3">@_msg</div>
}

@* Resumo do período *@
@if (_vendas != null && _vendas.Any())
{
    var finalizadas = _vendas.Where(v => v.Status == "Finalizada").ToList();
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="metric-card">
                <div class="metric-label">Total do período</div>
                <div class="metric-value" style="font-size:1.4rem">R$ @finalizadas.Sum(v => v.Total).ToString("N2")</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="metric-card">
                <div class="metric-label">Vendas finalizadas</div>
                <div class="metric-value" style="font-size:1.4rem">@finalizadas.Count</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="metric-card">
                <div class="metric-label">Ticket médio</div>
                <div class="metric-value" style="font-size:1.4rem">
                    R$ @(finalizadas.Any() ? (finalizadas.Sum(v => v.Total) / finalizadas.Count).ToString("N2") : "0,00")
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="metric-card">
                <div class="metric-label">Canceladas</div>
                <div class="metric-value" style="font-size:1.4rem">@_vendas.Count(v => v.Status == "Cancelada")</div>
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead><tr>
                    <th>Número</th><th>Data/Hora</th><th>Itens</th>
                    <th>Total</th><th>Pagamento</th><th>Operador</th>
                    <th>Status</th><th></th>
                </tr></thead>
                <tbody>
                    @if (_vendas == null)
                    {
                        <tr><td colspan="8" class="text-center py-4">
                            <div class="spinner-border spinner-border-sm text-primary"></div>
                        </td></tr>
                    }
                    else if (!_vendas.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4 small">
                            Nenhuma venda encontrada no período.
                        </td></tr>
                    }
                    else foreach (var v in _vendas)
                    {
                        <tr>
                            <td class="fw-medium">@v.Numero</td>
                            <td class="text-muted small">@v.DataVenda.ToLocalTime().ToString("dd/MM/yy HH:mm")</td>
                            <td>@v.QtdItens</td>
                            <td class="fw-medium">R$ @v.Total.ToString("N2")</td>
                            <td><span class="badge bg-light text-dark border">@v.FormaPagamento</span></td>
                            <td class="text-muted small">@(v.UsuarioNome ?? "—")</td>
                            <td>
                                <span class="badge @(v.Status=="Finalizada"?"bg-success":v.Status=="Cancelada"?"bg-danger":"bg-warning text-dark")">
                                    @v.Status
                                </span>
                            </td>
                            <td>
                                @if (Sessao.IsGerente && v.Status == "Finalizada")
                                {
                                    <button class="btn btn-link btn-sm text-danger p-0"
                                            @onclick="()=>ConfirmarCancelamento(v.Id, v.Numero)">
                                        Cancelar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (_confirmarCancelamento)
{
    <div class="modal d-block" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Cancelar venda @_numeroCancelamento?</h5>
                    <button class="btn-close" @onclick="()=>_confirmarCancelamento=false"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Motivo *</label>
                    <input @bind="_motivoCancelamento" class="form-control" placeholder="Informe o motivo" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="()=>_confirmarCancelamento=false">Voltar</button>
                    <button class="btn btn-danger" @onclick="ExecutarCancelamento">Confirmar cancelamento</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    IEnumerable<VendaResumoDto>? _vendas;
    DateTime _inicio = DateTime.Today, _fim = DateTime.Today;
    bool _confirmarCancelamento, _sucesso;
    Guid _idCancelamento;
    string _msg = "", _motivoCancelamento = "", _numeroCancelamento = "";

    protected override async Task OnInitializedAsync() => await Carregar();

    async Task Carregar()
    {
        if (!Sessao.EmpresaId.HasValue) return;
        _vendas = null;
        _vendas = await VendaService.ListarAsync(Sessao.EmpresaId.Value,
            _inicio, _fim.AddDays(1).AddTicks(-1));
    }

    void ConfirmarCancelamento(Guid id, string numero)
    {
        _idCancelamento = id;
        _numeroCancelamento = numero;
        _motivoCancelamento = "";
        _confirmarCancelamento = true;
    }

    async Task ExecutarCancelamento()
    {
        if (string.IsNullOrWhiteSpace(_motivoCancelamento) || !Sessao.EmpresaId.HasValue) return;
        try
        {
            await VendaService.CancelarAsync(_idCancelamento, _motivoCancelamento, Sessao.EmpresaId.Value);
            _msg = "Venda cancelada com sucesso."; _sucesso = true;
            _confirmarCancelamento = false;
            await Carregar();
        }
        catch (Exception ex) { _msg = ex.Message; _sucesso = false; }
    }
}
