@inherits LayoutComponentBase
@inject NavigationManager Nav

<AuthorizeView>
    <Authorized Context="auth">
        <div class="d-flex" style="min-height:100vh">

            @* ── Sidebar ── *@
            <nav class="sidebar d-flex flex-column" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-logo">
                    <i class="bi bi-shop me-2"></i>
                    <span class="sidebar-title">Gestor de Vendas</span>
                </div>
            </div>

            <ul class="sidebar-nav flex-grow-1">
                <AuthorizeView Roles="Admin" Context="_">
                    <li><NavLink href="/admin/dashboard" class="sidebar-link">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </NavLink></li>
                    <li><NavLink href="/admin/empresas" class="sidebar-link">
                        <i class="bi bi-building me-2"></i>Empresas
                    </NavLink></li>
                    <li><NavLink href="/admin/usuarios" class="sidebar-link">
                        <i class="bi bi-people me-2"></i>Usuários
                    </NavLink></li>
                </AuthorizeView>
                <AuthorizeView Roles="Gerente" Context="_">
                    <li><NavLink href="/gerente/dashboard" class="sidebar-link">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </NavLink></li>
                    <li><NavLink href="/gerente/produtos" class="sidebar-link">
                        <i class="bi bi-box-seam me-2"></i>Produtos
                    </NavLink></li>
                    <li><NavLink href="/gerente/estoque" class="sidebar-link">
                        <i class="bi bi-archive me-2"></i>Estoque
                    </NavLink></li>
                    <li><NavLink href="/gerente/vendas" class="sidebar-link">
                        <i class="bi bi-receipt me-2"></i>Vendas
                    </NavLink></li>
                    <li><NavLink href="/gerente/relatorios" class="sidebar-link">
                        <i class="bi bi-bar-chart me-2"></i>Relatórios
                    </NavLink></li>
                    <li><NavLink href="/gerente/usuarios" class="sidebar-link">
                        <i class="bi bi-people me-2"></i>Usuários
                    </NavLink></li>
                    <li><NavLink href="/gerente/pdv" class="sidebar-link">
                        <i class="bi bi-cart me-2"></i>PDV
                    </NavLink></li>
                </AuthorizeView>
                <AuthorizeView Roles="Operador" Context="_">
                    <li><NavLink href="/operador/pdv" class="sidebar-link">
                        <i class="bi bi-cart me-2"></i>PDV
                    </NavLink></li>
                </AuthorizeView>
            </ul>

            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <i class="bi bi-person-circle me-2"></i>
                    <div>
                        <div class="sidebar-user-nome">@auth.User.Identity?.Name</div>
                        <div class="sidebar-user-perfil">
                            @(auth.User.IsInRole("Admin") ? "Administrador" :
                              auth.User.IsInRole("Gerente") ? "Gerente" : "Operador")
                        </div>
                    </div>
                </div>
                <button class="btn btn-outline-secondary btn-sm w-100 mt-2" @onclick="Sair">
                    <i class="bi bi-box-arrow-right me-1"></i>Sair
                </button>
            </div>
        </nav>

        @* ── Conteúdo principal ── *@
        <div class="main-content flex-grow-1">
            <header class="topbar d-flex align-items-center d-md-none">
                <button class="btn btn-sm btn-outline-secondary me-2" @onclick="ToggleSidebar">
                    <i class="bi bi-list"></i>
                </button>
                <strong>Sistema</strong>
            </header>
            <div class="page-content">
                @Body
            </div>
        </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    void Sair() => Nav.NavigateTo("/conta/sair", forceLoad: true);

    void ToggleSidebar()
    {
        // JS interop pode ser adicionado para toggle mobile
    }
}
